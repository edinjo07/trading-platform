{
  "installCommand": "npm install",
  "buildCommand": "[ -d client ] && cd client && npm run build || npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/[...path].ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
