# ──────────────────────────────────────────────────────────
# TradeX Pro — Server environment variables
# Copy this file to .env and fill in the values.
# On Railway: set these in the "Variables" tab of your service.
# ──────────────────────────────────────────────────────────

# Server
NODE_ENV=production
PORT=5000

# Auth
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=https://trading-platform-client.vercel.app,http://localhost:3000,http://localhost:5173

# Market data
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
